{
  "id": "template.wechat-draft-assistant",
  "name": "微信未读草稿助手模板",
  "description": "非侵入式 macOS 桌面辅助 PoC：先截取微信当前窗口并通过多模态模型识别可见未读，再可选把回复草稿写入剪贴板；不自动粘贴或发送。",
  "version": "0.1.0",
  "entry": {
    "type": "node",
    "command": "node",
    "args": [
      "index.js"
    ]
  },
  "capabilities": {
    "agentCallable": false,
    "commandCallable": true,
    "scheduledCallable": false,
    "hasUi": false
  },
  "permissions": {
    "network": false,
    "filesystem": [
      "workspace"
    ],
    "requiresOwnerApproval": false,
    "desktopAutomation": {
      "screenCapture": true,
      "accessibility": true,
      "clipboard": true,
      "keyboardInput": false,
      "autoSend": false
    }
  }
}
