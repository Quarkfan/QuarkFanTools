{
  "id": "template.wechat-draft-assistant",
  "name": "微信草稿助手模板",
  "description": "非侵入式 macOS 桌面辅助 PoC：为指定微信联系人生成并粘贴回复草稿，默认不自动发送。",
  "version": "0.1.0",
  "entry": {
    "type": "node",
    "command": "node",
    "args": [
      "index.js"
    ]
  },
  "capabilities": {
    "agentCallable": false,
    "commandCallable": true,
    "scheduledCallable": false,
    "hasUi": false
  },
  "permissions": {
    "network": false,
    "filesystem": [
      "workspace"
    ],
    "requiresOwnerApproval": true,
    "desktopAutomation": {
      "screenCapture": true,
      "accessibility": true,
      "clipboard": true,
      "keyboardInput": true,
      "autoSend": false
    }
  }
}
