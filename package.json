{
  "name": "quarkfantools",
  "version": "1.6.7",
  "private": true,
  "description": "Local macOS Feishu skill agent powered by Claude Agent SDK",
  "main": "dist-electron/main.js",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.177",
    "@larksuite/cli": "1.0.53",
    "fast-xml-parser": "^5.8.0",
    "isomorphic-git": "^1.38.4",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "@types/unzipper": "^0.10.11",
    "concurrently": "9.2.1",
    "electron": "42.4.0",
    "electron-builder": "26.15.3",
    "typescript": "5.9.3",
    "vite": "7.2.2",
    "wait-on": "9.0.3"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5173 dist-electron/main.js && electron .\"",
    "build": "rm -rf dist dist-electron && tsc -p tsconfig.electron.json && cp electron/preload.cjs dist-electron/preload.cjs && vite build",
    "start": "npm run build && electron .",
    "test": "npm run build && node --test dist-electron/tests/*.test.js",
    "pack:prepare": "bash scripts/prepare-universal-lark-cli.sh && bash scripts/prepare-universal-claude.sh",
    "pack:mac": "npm run pack:mac:arm64 && npm run pack:mac:x64",
    "pack:mac:arm64": "npm run build && npm run pack:prepare && electron-builder --mac --arm64 --config.directories.output=release/arm64",
    "pack:mac:x64": "npm run build && npm run pack:prepare && electron-builder --mac --x64 --config.directories.output=release/x64"
  },
  "build": {
    "appId": "tech.blacklake.quarkfantools",
    "productName": "QuarkfanTools",
    "asar": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/@larksuite/cli/**",
      "!node_modules/@anthropic-ai/claude-agent-sdk-darwin-*/**"
    ],
    "extraResources": [
      {
        "from": "config/default.json",
        "to": "config/default.json"
      },
      {
        "from": "node_modules/@larksuite/cli",
        "to": "runtime/lark-cli"
      },
      {
        "from": "runtime/claude/${arch}",
        "to": "runtime/claude/${arch}"
      },
      {
        "from": "builtin-skills",
        "to": "builtin-skills"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
